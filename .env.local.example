# Copy this file to .env.local and fill in your values
# .env.local is gitignored and never committed

# Admin login password (default used when not set: tveco2026)
VITE_ADMIN_PASSWORD=your_secure_password_here

# Set to true to use Spring Boot BFF instead of localStorage
VITE_USE_API=false

# Backend base URL (only needed when VITE_USE_API=true)
VITE_API_URL=http://localhost:8080/api
